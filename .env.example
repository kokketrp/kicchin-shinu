# ============================================
# kicchin-shinu — 環境変数テンプレート
# ============================================
# コピーして `.env` を作成し、値を入れる。
# `.env` は .gitignore 済み（コミットしない）。
# Cloudflare Pages にも同じ値を Settings → Environment variables で登録すること。

# --- お問い合わせフォーム ---
# Web3Forms のアクセスキー（https://web3forms.com/ で取得）
# 全サイトで共通の1つのキーを使う（nishimotoclaude (at) gmail.com に紐付け済み）
# 詳細：マネタイズ/Claudeマネタイズ/MULTI_SITE_CONTACT_FORM.md
PUBLIC_WEB3FORMS_KEY=YOUR_KEY_HERE

# --- アフィリエイト（将来用） ---
# RAKUTEN_APP_ID=
# RAKUTEN_AFFILIATE_ID=
# AMAZON_ASSOCIATE_ID=

# --- アクセス解析（将来用） ---
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

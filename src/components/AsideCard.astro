---
// AsideCard — 閑話 / 番外 用カード
// F派生（薄め・小さめ）：方眼薄い + 検印ミニ + カテゴリ別効果色
export interface Props {
  kind: 'interlude' | 'extra';
  number: number;
  title: string;
  excerpt?: string;
  mark?: string;
  pubDate: Date;
  href: string;
  perspective?: string;  // extra のみ：視点ラベル
  eyecatch?: string;
}

const { kind, number, title, excerpt, mark, pubDate, href, perspective, eyecatch } = Astro.props;
const numStr = String(number).padStart(2, '0');
const dateStr = pubDate.toISOString().slice(0, 10);
const labelText = kind === 'interlude' ? '閑話' : '番外';
---
<a href={href} class={`aside-card aside-card--${kind}`}>
  <div class="aside-card__paper" aria-hidden="true"></div>

  <div class="aside-card__top">
    <span class="aside-card__label">{labelText} #{numStr}</span>
    {eyecatch && <span class="aside-card__eyecatch">{eyecatch}</span>}
  </div>

  {excerpt ? (
    <p class="aside-card__excerpt" set:html={excerpt} />
  ) : (
    <h3 class="aside-card__title">{title}</h3>
  )}
  {excerpt && <h4 class="aside-card__title aside-card__title--sub">{title}</h4>}

  <div class="aside-card__bottom">
    <span class="aside-card__date">{dateStr}</span>
    {perspective && <span class="aside-card__perspective">— {perspective}</span>}
  </div>

  {mark && (
    <div class="aside-card__mark" aria-label={`印 ${mark}`}>
      <span>{mark}</span>
    </div>
  )}
</a>

<style>
  .aside-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px 24px 18px;
    background: var(--bg-elev);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    overflow: hidden;
    isolation: isolate;
    transition: transform .25s, box-shadow .25s;
  }
  .aside-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
  }
  .aside-card:hover .aside-card__mark {
    transform: rotate(-3deg) scale(1.06);
  }

  /* 方眼背景（薄め） */
  .aside-card__paper {
    position: absolute;
    inset: 10px;
    background-size: 14px 14px;
    border-radius: 4px;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }
  .aside-card--interlude {
    border: 1px dashed var(--hairline);
  }
  .aside-card--interlude .aside-card__paper {
    background-image:
      linear-gradient(to right, rgba(232, 174, 84, 0.15) 0 1px, transparent 1px 14px),
      linear-gradient(to bottom, rgba(232, 174, 84, 0.15) 0 1px, transparent 1px 14px);
    border: 1px dashed rgba(232, 174, 84, 0.35);
  }
  .aside-card--interlude:hover {
    border-color: var(--secondary);
    border-style: solid;
  }

  .aside-card--extra {
    border: 1px solid var(--hairline);
    background: linear-gradient(180deg, var(--bg-elev) 60%, var(--panel-2));
  }
  .aside-card--extra .aside-card__paper {
    background-image:
      linear-gradient(to right, rgba(184, 74, 54, 0.13) 0 1px, transparent 1px 14px),
      linear-gradient(to bottom, rgba(184, 74, 54, 0.13) 0 1px, transparent 1px 14px);
    border: 1px solid rgba(184, 74, 54, 0.20);
  }
  .aside-card--extra:hover {
    border-color: var(--accent);
  }

  /* 上段：ラベル + アイキャッチ */
  .aside-card__top {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .aside-card__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border-radius: 4px;
    font-weight: 500;
  }
  .aside-card--interlude .aside-card__label {
    color: var(--secondary);
    background: var(--secondary-soft);
  }
  .aside-card--extra .aside-card__label {
    color: var(--accent-deep);
    background: var(--accent-soft);
  }
  .aside-card__eyecatch {
    font-size: 22px;
    opacity: 0.85;
  }

  /* タイトル断片 */
  .aside-card__excerpt {
    position: relative;
    z-index: 1;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    letter-spacing: 0.01em;
  }
  .aside-card__excerpt :global(em) {
    font-style: normal;
    background-image: linear-gradient(transparent 70%, var(--secondary-soft) 70%, var(--secondary-soft) 96%, transparent 96%);
    color: var(--accent-deep);
    padding: 0 0.04em;
  }
  .aside-card--extra .aside-card__excerpt :global(em) {
    background-image: linear-gradient(transparent 70%, var(--accent-soft) 70%, var(--accent-soft) 96%, transparent 96%);
  }

  .aside-card__title {
    position: relative;
    z-index: 1;
    font-family: var(--font-heading);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
    color: var(--text-dim);
    font-weight: 500;
  }
  .aside-card__title--sub {
    font-size: 12px;
    color: var(--muted);
  }

  .aside-card__bottom {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 10px;
    align-items: baseline;
    margin-top: auto;
    padding-top: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .aside-card__perspective {
    font-style: italic;
  }

  /* 検印ミニ */
  .aside-card__mark {
    position: absolute;
    bottom: 14px;
    right: 14px;
    z-index: 2;
    width: 36px;
    height: 36px;
    line-height: 1;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 18px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elev);
    transform: rotate(-6deg);
    transition: transform .25s;
  }
  .aside-card--interlude .aside-card__mark {
    color: var(--secondary);
    border: 1.5px solid var(--secondary);
  }
  .aside-card--extra .aside-card__mark {
    color: var(--accent-deep);
    border: 1.5px solid var(--accent-deep);
  }
</style>

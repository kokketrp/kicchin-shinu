---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import QuoteStrip from '../components/QuoteStrip.astro';
import SiteFooter from '../components/SiteFooter.astro';
import EssayCard from '../components/EssayCard.astro';
import InterludeCard from '../components/InterludeCard.astro';
import ExtraCard from '../components/ExtraCard.astro';
import ReportCard from '../components/ReportCard.astro';

// 全件取得（drafts も TOP には表示する）
const allEssays = (await getCollection('essays')).sort((a, b) => a.data.episode - b.data.episode);
const allInterludes = (await getCollection('interludes')).sort((a, b) => a.data.number - b.data.number);
const allExtras = (await getCollection('extras')).sort((a, b) => a.data.number - b.data.number);
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// カテゴリ → 比較レポートの色割り
function colorOf(category?: string): 1 | 2 | 3 | 4 {
  if (!category) return 1;
  const c = category.toLowerCase();
  if (c.includes('dishwasher')) return 2;
  if (c.includes('pressure')) return 3;
  if (c.includes('bakery') || c.includes('bread')) return 4;
  return 1;
}
function tagVariantOf(category?: string): 'default' | 'mustard' | 'neutral' {
  if (!category) return 'default';
  const c = category.toLowerCase();
  if (c.includes('dishwasher')) return 'mustard';
  if (c.includes('bakery') || c.includes('bread')) return 'neutral';
  return 'default';
}

// 第N話 → 想定カテゴリラベル（drafts用）
const draftCategoryByEpisode: Record<number, string> = {
  2: '食洗機',
  3: 'ベーカリー',
  4: '時短家電',
  5: '予算別',
  6: '一人暮らし',
};
const draftExpectedByEpisode: Record<number, string> = {
  2: 'EXPECTED 2026.06',
  3: 'EXPECTED 2026.06',
  4: 'EXPECTED 2026.07',
  5: 'EXPECTED 2026.08',
  6: 'EXPECTED 2026.09',
};
---
<BaseLayout>
  <SiteHeader />
  <Hero />
  <QuoteStrip />

  {/* ============== 本編 連載目次 (E3) ============== */}
  <section class="section" id="essays" data-screen-label="01 Top — Essays">
    <div class="container">
      <div class="section-head">
        <h2 class="top-section__h"><small>SECTION · ESSAYS</small>連載・本編</h2>
        <p class="top-section__lead">
          台所と暮らしのあわいを、時系列で書いています。<br>
          急がず、第一話から、または気になる話から、お読みください。
        </p>
      </div>

      <div class="essay-toc">
        {allEssays.map((e) => (
          <EssayCard
            episode={e.data.episode}
            title={e.data.title}
            excerpt={e.data.excerpt}
            mark={e.data.mark}
            pubDate={e.data.draft ? undefined : e.data.pubDate}
            href={e.data.draft ? undefined : `/essay/${e.id}/`}
            readTime={e.data.draft ? undefined : '14 MIN'}
            draft={e.data.draft}
            expectedDate={e.data.draft ? draftExpectedByEpisode[e.data.episode] : undefined}
            category={draftCategoryByEpisode[e.data.episode] ?? '自動調理'}
          />
        ))}
      </div>

      <div class="section-foot">
        <a href="/essay/" class="link-arrow">本編 全話一覧へ →</a>
      </div>
    </div>
  </section>

  {/* ============== 閑話 (I2) + 番外編 (X1) ============== */}
  <section class="section section--panel" id="aside" data-screen-label="01 Top — Aside">
    <div class="container">
      <div class="section-head">
        <h2 class="top-section__h"><small>SECTION · INTERLUDES &amp; EXTRAS</small>余白の文章 ／ 特別号</h2>
        <p class="top-section__lead">
          連載の脇道として、ちいさな道具のはなし（閑話）と、別視点・季節企画（番外編）を書いています。
        </p>
      </div>

      {/* 閑話 horizontal strip stack */}
      <div class="aside-block">
        <h3 class="aside-block__h">閑話休題 ── INTERLUDES</h3>
        <div class="interlude-stack">
          {allInterludes.map((i) => (
            <InterludeCard
              number={i.data.number}
              title={i.data.title}
              mark={i.data.mark}
              pubDate={i.data.draft ? undefined : i.data.pubDate}
              href={i.data.draft ? undefined : `/interlude/${i.id}/`}
              readTime={i.data.draft ? undefined : '5 MIN'}
              eyecatch={i.data.eyecatch}
              relatedEssay={i.data.relatedEssay}
              draft={i.data.draft}
            />
          ))}
        </div>
      </div>

      {/* 番外編 grid */}
      <div class="aside-block">
        <h3 class="aside-block__h">番外編 ── EXTRAS</h3>
        <div class="extra-grid">
          {allExtras.map((e) => (
            <ExtraCard
              number={e.data.number}
              title={e.data.title}
              mark={e.data.mark}
              pubDate={e.data.draft ? undefined : e.data.pubDate}
              href={e.data.draft ? undefined : `/extra/${e.id}/`}
              readTime={e.data.draft ? undefined : '7 MIN'}
              eyecatch={e.data.eyecatch}
              perspective={e.data.perspective}
              draft={e.data.draft}
            />
          ))}
        </div>
      </div>

      <div class="section-foot section-foot--split">
        <a href="/interlude/" class="link-arrow">閑話休題 一覧へ →</a>
        <a href="/extra/" class="link-arrow">番外編 一覧へ →</a>
      </div>
    </div>
  </section>

  {/* ============== 比較レポート (P1) ============== */}
  <section class="section" id="reports" data-screen-label="01 Top — Reports">
    <div class="container">
      <div class="section-head">
        <h2 class="top-section__h"><small>SECTION · REPORTS</small>比較レポート</h2>
        <p class="top-section__lead">
          家電のスペック比較。容量・価格・洗いやすさで、断定せずに整理しています。<br>
          エッセイで読み物として進んだあと、買い物の段で、こちらをご覧ください。
        </p>
      </div>

      <div class="report-grid">
        {posts.slice(0, 4).map((p, i) => (
          <ReportCard
            vol={posts.length - i + 8}
            title={p.data.title}
            pubDate={p.data.pubDate}
            href={`/posts/${p.id}/`}
            category={p.data.category}
            readTime="14 MIN"
            colorIndex={colorOf(p.data.category)}
            tagVariant={tagVariantOf(p.data.category)}
            description={p.data.description}
          />
        ))}
      </div>

      <div class="section-foot">
        <a href="/posts/" class="link-arrow">比較レポート すべて見る →</a>
      </div>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>

<style>
  .section-head { margin-bottom: 40px; }
  .top-section__h {
    font-family: var(--font-heading); font-weight: 800;
    font-size: clamp(22px, 3vw, 30px);
    color: var(--text);
    margin: 0 0 12px;
    letter-spacing: 0.01em;
  }
  .top-section__h small {
    display: block;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em;
    color: var(--accent-deep); margin-bottom: 6px; font-weight: 500; text-transform: uppercase;
  }
  .top-section__lead {
    color: var(--text-dim); font-size: 14.5px; line-height: 1.95;
    max-width: 620px;
  }

  .section-foot { margin-top: 36px; text-align: center; }
  .section-foot--split { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
  .link-arrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--accent-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-deep);
    padding-bottom: 3px;
    transition: color .2s, border-color .2s;
    text-transform: uppercase;
  }
  .link-arrow:hover { color: var(--accent); border-color: var(--accent); }

  /* essay-toc 外枠 */
  .essay-toc {
    background: var(--bg-elev);
    border: 1px solid var(--hairline);
    border-radius: 14px;
    overflow: hidden;
  }

  /* aside */
  .aside-block { margin-bottom: 40px; }
  .aside-block__h {
    font-family: var(--font-heading); font-weight: 700;
    font-size: 14px; letter-spacing: 0.18em;
    color: var(--accent-deep);
    margin: 0 0 18px;
    text-transform: uppercase;
  }
  .interlude-stack { display: flex; flex-direction: column; gap: 12px; }
  .extra-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }

  /* reports */
  .report-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }
</style>

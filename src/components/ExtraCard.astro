---
import Glyph from './Glyph.astro';

// ExtraCard — X1 アクセント濃淡 + 視点ラベル付き
// 番外編・特別号
export interface Props {
  number: number;
  title: string;
  mark?: string;           // 季節印 or 視点印（夏/夫/独 等）
  pubDate?: Date;
  href?: string;
  readTime?: string;
  eyecatch?: string;
  perspective?: string;    // 「母から見た、子どもの夏」「夫視点」等
  draft?: boolean;
  tagLabel?: string;       // body部分のタグ表示（"番外・夏休み号" 等）
}

const {
  number,
  title,
  mark,
  pubDate,
  href,
  readTime,
  eyecatch,
  perspective,
  draft = false,
  tagLabel = '番外編',
} = Astro.props;

const numStr = String(number).padStart(2, '0');
const dateStr = pubDate ? pubDate.toISOString().slice(0, 10).replace(/-/g, '.') : '想定';
const stampClass = `stamp stamp--md x1-thumb__stamp${draft ? ' stamp--draft' : ''}`;
---
<a class={`card extra-card${draft ? ' is-draft' : ''}`} href={href}>
  <div class={`card-thumb x1-thumb paper paper--coral${draft ? ' paper--faint' : ''}`}>
    {draft && <span class="draft-banner">想定</span>}
    <div class="x1-thumb__top">
      <div class="x1-thumb__num">
        <small>EXTRA</small>
        <span class="hash">#</span>{numStr}
      </div>
      {perspective && <span class="x1-thumb__viewpoint">{perspective}</span>}
    </div>
    <p class="x1-thumb__title">
      {eyecatch && <Glyph name={eyecatch} size={26} tone="coral" />}
      <span class="x1-thumb__title-text">{title}</span>
    </p>
    <div class="x1-thumb__bot">
      <span>{dateStr}{readTime && ` / ${readTime}`}</span>
      {mark && <span class={stampClass}>{mark}</span>}
    </div>
  </div>
  <div class="card-body">
    <span class="card-tag">{tagLabel}</span>
    <h4 class="card-title">{title}</h4>
    <div class="card-meta">
      <span>{dateStr}</span>
      {readTime && <span>{readTime}</span>}
    </div>
  </div>
</a>

<style>
  /* ===== generic card ===== */
  .card {
    background: var(--bg-elev);
    border: 1px solid var(--hairline);
    border-radius: 14px;
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform .25s, box-shadow .25s;
    text-decoration: none;
    color: var(--text);
  }
  .card:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(45, 36, 25, 0.08); }
  .card-thumb { aspect-ratio: 16 / 9; position: relative; overflow: hidden; }
  .card-body { padding: 18px 20px 22px; display: flex; flex-direction: column; gap: 10px; }
  .card-tag {
    align-self: flex-start; font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-deep);
    background: var(--accent-soft); padding: 4px 9px; border-radius: 999px;
  }
  .card-title {
    font-family: var(--font-heading); font-weight: 700; font-size: 15px; line-height: 1.65;
    color: var(--text);
  }
  .card-meta {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
    color: var(--muted); text-transform: uppercase; display: flex; gap: 12px; margin-top: 2px;
  }

  /* ===== x1-thumb (X1 pattern) ===== */
  .extra-card .card-thumb { background: var(--accent-soft); }
  .x1-thumb {
    padding: 18px 22px;
    display: flex; flex-direction: column; gap: 10px; justify-content: space-between;
  }
  .x1-thumb__top {
    display: flex; justify-content: space-between; align-items: flex-start;
    z-index: 2;
  }
  .x1-thumb__num {
    font-family: var(--font-serif); font-weight: 700; font-size: 28px;
    color: var(--accent-deep); line-height: 1;
  }
  .x1-thumb__num .hash { color: var(--accent); font-weight: 500; }
  .x1-thumb__num small {
    display: block;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em;
    color: var(--accent); font-weight: 500; margin-bottom: 6px; text-transform: uppercase;
  }
  .x1-thumb__viewpoint {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-heading); font-weight: 700; font-size: 11px;
    color: var(--bg);
    background: var(--accent-deep);
    padding: 6px 10px;
    border-radius: 4px;
    letter-spacing: 0.05em;
    z-index: 2;
  }
  .x1-thumb__viewpoint::before {
    content: "視点";
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    opacity: 0.7;
    margin-right: 4px;
    border-right: 1px solid rgba(255,255,255,0.4);
    padding-right: 6px;
  }
  .x1-thumb__title {
    font-family: var(--font-serif); font-weight: 600; font-size: 16px; line-height: 1.65;
    color: var(--text); max-width: 22ch; z-index: 2;
    margin: 0;
    display: flex; align-items: flex-start; gap: 10px;
  }
  .x1-thumb__title-text { flex: 1; }
  .x1-thumb__bot {
    display: flex; justify-content: space-between; align-items: flex-end;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em;
    color: var(--accent-deep); text-transform: uppercase; z-index: 2;
  }
  .x1-thumb__stamp { z-index: 3; }

  /* draft */
  .is-draft .x1-thumb__num { color: var(--muted); }
  .is-draft .x1-thumb__title { color: var(--text-dim); }
  .is-draft .x1-thumb__viewpoint { background: var(--text-dim); }
  .is-draft .x1-thumb__bot { color: var(--muted); }

  .draft-banner {
    position: absolute;
    top: 14px; right: 14px;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em;
    color: var(--muted); border: 1px dashed var(--muted); padding: 4px 8px;
    border-radius: 999px; text-transform: uppercase;
    background: rgba(251, 247, 242, 0.85);
    z-index: 4;
  }
</style>

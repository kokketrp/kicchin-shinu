---
// ProductBox — 商品 CTA ボックス（楽天/Amazon、F-system 統合）
//
// 2 つの使い方：
//
// A) keyword 駆動（推奨）：ビルド時に楽天 API 検索
//    <ProductBox keyword="シャープ ヘルシオ ホットクック KN-HW24G" />
//    → 楽天API: 商品名・価格・画像・URL を自動取得
//    → Amazon: 同じキーワードでアソシエイトID付き検索 URL を自動生成
//
// B) 完全手動：name / rakutenUrl / amazonUrl をすべて指定
//    <ProductBox name="..." rakutenUrl="..." amazonUrl="..." />
//
// keyword 駆動でも、props で個別上書きできる（例: 価格だけ別 / 画像だけ別 etc）
import { findRakutenItem } from '../lib/rakuten';
import { buildAmazonSearchUrl, buildRakutenSearchUrl } from '../lib/affiliate';

export interface Props {
  keyword?: string;         // ← keyword 駆動の起点
  name?: string;
  brand?: string;
  price?: string;
  rakutenUrl?: string;
  amazonUrl?: string;
  image?: string;
  features?: string[];
  specs?: string[];         // alias: 旧API互換
  rank?: number;
  minPrice?: number;        // 価格レンジで絞り込み（API検索時のみ）
  maxPrice?: number;
}

const props = Astro.props;

// keyword があれば楽天 API から商品情報取得
let fetched: Awaited<ReturnType<typeof findRakutenItem>> = null;
if (props.keyword && !props.rakutenUrl) {
  try {
    fetched = await findRakutenItem(props.keyword, {
      minPrice: props.minPrice,
      maxPrice: props.maxPrice,
    });
  } catch (e) {
    console.warn(`[ProductBox] 楽天API取得失敗 keyword="${props.keyword}":`, e);
  }
}

// プロパティ解決（手動指定 > API 取得 > フォールバック検索URL）
const name = props.name ?? fetched?.itemName ?? props.keyword ?? '商品名未設定';
const price = props.price ?? (fetched?.itemPrice ? `¥${fetched.itemPrice.toLocaleString('ja-JP')}` : undefined);
const image = props.image ?? fetched?.imageUrlLarge ?? fetched?.imageUrl ?? undefined;
const rakutenUrl = props.rakutenUrl
  ?? fetched?.affiliateUrl
  ?? fetched?.itemUrl
  ?? (props.keyword ? buildRakutenSearchUrl(props.keyword) : undefined);
const amazonUrl = props.amazonUrl
  ?? (props.keyword ? buildAmazonSearchUrl(props.keyword) : undefined);

const items = props.features ?? props.specs ?? [];
const rankStr = props.rank !== undefined ? `No.${String(props.rank).padStart(2, '0')}` : null;
---
<div class="product paper paper--faint">
  <div class={`product__inner${!image ? ' product__inner--no-image' : ''}`}>
    {image && (
      <div class="product__thumb">
        <img src={image} alt={name} loading="lazy" />
      </div>
    )}
    <div class="product__body">
      <div class="product__head">
        {rankStr && <span class="product__rank">{rankStr}</span>}
        {props.brand && <span class="product__brand">{props.brand}</span>}
      </div>
      <h4 class="product__name">{name}</h4>
      {price && <div class="product__price">{price}</div>}
      {items.length > 0 && (
        <ul class="product__features">
          {items.map((f) => <li>{f}</li>)}
        </ul>
      )}
      <div class="product__ctas">
        {rakutenUrl && (
          <a class="product__cta product__cta--rakuten" href={rakutenUrl} target="_blank" rel="nofollow sponsored noopener">
            楽天で見る
          </a>
        )}
        {amazonUrl && (
          <a class="product__cta product__cta--amazon" href={amazonUrl} target="_blank" rel="nofollow sponsored noopener">
            Amazonで見る
          </a>
        )}
      </div>
      <div class="product__disclosure">※ 価格は変動します。最新は各ストアでご確認ください。</div>
    </div>
  </div>
</div>

<style>
  .product {
    position: relative;
    margin: 32px 0;
    border: 1px solid var(--hairline);
    border-left: 4px solid var(--accent);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .product::before { inset: 12px; border-radius: 4px; }
  .product__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 22px 28px;
  }
  .product__inner--no-image {
    grid-template-columns: 1fr;
  }
  @media (max-width: 640px) {
    .product__inner { grid-template-columns: 1fr; }
  }
  .product__thumb img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    background: var(--panel);
  }
  .product__head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 6px;
  }
  .product__rank {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 13px;
    color: var(--accent-deep);
    letter-spacing: 0.04em;
  }
  .product__brand {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .product__name {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.55;
    margin: 0 0 10px;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .product__price {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--accent-deep);
    font-weight: 500;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
  }
  .product__features {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    font-size: 13.5px;
    color: var(--text-dim);
  }
  .product__features li {
    padding: 4px 0 4px 14px;
    line-height: 1.75;
    position: relative;
  }
  .product__features li::before {
    content: "─";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .product__ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .product__cta {
    display: inline-block;
    padding: 11px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.04em;
    font-family: var(--font-heading);
    transition: transform .15s, box-shadow .2s;
  }
  .product__cta:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0,0,0,0.12); }
  .product__cta--rakuten {
    background: var(--rakuten);
    color: #fff;
  }
  .product__cta--amazon {
    background: var(--amazon);
    color: #1a1a1a;
  }
  .product__disclosure {
    margin-top: 14px;
    font-size: 11px;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
</style>

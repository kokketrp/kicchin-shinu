# ============================================
# kicchin-shinu — 環境変数テンプレート
# ============================================
# コピーして `.env` を作成し、値を入れる。
# `.env` は .gitignore 済み（コミットしない）。
# Cloudflare Pages にも同じ値を Settings → Environment variables で登録すること。

# --- お問い合わせフォーム ---
# Web3Forms のアクセスキー（https://web3forms.com/ で取得）
# 全サイトで共通の1つのキーを使う（nishimotoclaude (at) gmail.com に紐付け済み）
PUBLIC_WEB3FORMS_KEY=YOUR_KEY_HERE

# --- 楽天ウェブサービスAPI ---
# 楽天デベロッパーで取得（https://webservice.rakuten.co.jp/）
# 2026-02-10 以降は accessKey 必須、Origin ヘッダーも要登録
# deskscape と同じ APP_ID / ACCESS_KEY を流用可能
RAKUTEN_APP_ID=
RAKUTEN_AFFILIATE_ID=
RAKUTEN_ACCESS_KEY=

# 楽天デベロッパー側のアプリ設定で「Origin」に登録した URL
# 本番ドメインに合わせる（変更時は楽天デベロッパー側も同期）
RAKUTEN_ORIGIN=https://kicchin-shinu.com

# --- Amazon Associates ---
# 当面は deskscape-22 を流用（kicchin 専用 ID 取得したら書き換え）
AMAZON_ASSOCIATE_ID=deskscape-22

# --- アクセス解析（将来用） ---
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- ビルド環境（Cloudflare Pages 推奨）---
NODE_VERSION=20

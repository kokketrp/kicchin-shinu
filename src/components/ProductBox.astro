---
// ProductBox — 商品 CTA ボックス（楽天/Amazon、F-system 統合）
export interface Props {
  name: string;
  brand?: string;
  price?: string;
  rakutenUrl?: string;
  amazonUrl?: string;
  image?: string;
  features?: string[];
  specs?: string[];         // alias: 旧API互換（MDXで specs={[...]} と書かれているため）
  rank?: number;            // 順位を入れたい場合（No.01 表示）
}

const { name, brand, price, rakutenUrl, amazonUrl, image, features, specs, rank } = Astro.props;
const items = features ?? specs ?? [];
const rankStr = rank !== undefined ? `No.${String(rank).padStart(2, '0')}` : null;
---
<div class="product paper paper--faint">
  <div class={`product__inner${!image ? ' product__inner--no-image' : ''}`}>
    {image && (
      <div class="product__thumb">
        <img src={image} alt={name} loading="lazy" />
      </div>
    )}
    <div class="product__body">
      <div class="product__head">
        {rankStr && <span class="product__rank">{rankStr}</span>}
        {brand && <span class="product__brand">{brand}</span>}
      </div>
      <h4 class="product__name">{name}</h4>
      {price && <div class="product__price">{price}</div>}
      {items.length > 0 && (
        <ul class="product__features">
          {items.map((f) => <li>{f}</li>)}
        </ul>
      )}
      <div class="product__ctas">
        {rakutenUrl && (
          <a class="product__cta product__cta--rakuten" href={rakutenUrl} target="_blank" rel="nofollow sponsored noopener">
            楽天で見る
          </a>
        )}
        {amazonUrl && (
          <a class="product__cta product__cta--amazon" href={amazonUrl} target="_blank" rel="nofollow sponsored noopener">
            Amazonで見る
          </a>
        )}
      </div>
      <div class="product__disclosure">※ 価格は変動します。最新は各ストアでご確認ください。</div>
    </div>
  </div>
</div>

<style>
  .product {
    position: relative;
    margin: 32px 0;
    border: 1px solid var(--hairline);
    border-left: 4px solid var(--accent);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .product::before { inset: 12px; border-radius: 4px; }
  .product__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 22px 28px;
  }
  .product__inner--no-image {
    grid-template-columns: 1fr;
  }
  @media (max-width: 640px) {
    .product__inner { grid-template-columns: 1fr; }
  }
  .product__thumb img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    background: var(--panel);
  }
  .product__head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 6px;
  }
  .product__rank {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 13px;
    color: var(--accent-deep);
    letter-spacing: 0.04em;
  }
  .product__brand {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .product__name {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.55;
    margin: 0 0 10px;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .product__price {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--accent-deep);
    font-weight: 500;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
  }
  .product__features {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    font-size: 13.5px;
    color: var(--text-dim);
  }
  .product__features li {
    padding: 4px 0 4px 14px;
    line-height: 1.75;
    position: relative;
  }
  .product__features li::before {
    content: "─";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .product__ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .product__cta {
    display: inline-block;
    padding: 11px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.04em;
    font-family: var(--font-heading);
    transition: transform .15s, box-shadow .2s;
  }
  .product__cta:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0,0,0,0.12); }
  .product__cta--rakuten {
    background: var(--rakuten);
    color: #fff;
  }
  .product__cta--amazon {
    background: var(--amazon);
    color: #1a1a1a;
  }
  .product__disclosure {
    margin-top: 14px;
    font-size: 11px;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
</style>

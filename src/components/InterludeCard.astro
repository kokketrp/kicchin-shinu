---
import Glyph from './Glyph.astro';

// InterludeCard — I2 横長ストリップ
// 本編タイムラインの間に挟み込めるサイズ感
export interface Props {
  number: number;
  title: string;
  mark?: string;
  pubDate?: Date;
  href?: string;
  readTime?: string;
  eyecatch?: string;       // ☕ 等の絵文字（Glyph で SVG 描画される）
  relatedEssay?: number;   // "← 第NN話の余白から"
  draft?: boolean;
}

const {
  number,
  title,
  mark = '閑',
  pubDate,
  href,
  readTime,
  eyecatch,
  relatedEssay,
  draft = false,
} = Astro.props;

const numStr = String(number).padStart(2, '0');
const dateStr = pubDate ? pubDate.toISOString().slice(0, 10).replace(/-/g, '.') : '想定';
const Tag = draft || !href ? 'div' : 'a';
const stampClass = `stamp stamp--sm interlude-strip__stamp${draft ? ' stamp--draft' : ' stamp--mustard'}`;
---
<Tag class={`interlude-strip${draft ? ' is-draft' : ''}`} href={href}>
  <div class="interlude-strip__num">
    <small>INTERLUDE</small>
    #{numStr}
  </div>
  <div class="interlude-strip__body">
    <div class="interlude-strip__title">
      {eyecatch && <Glyph name={eyecatch} size={22} tone="mustard" />}
      <span class="interlude-strip__title-text">{title}</span>
    </div>
    <div class="interlude-strip__meta">
      <span>{dateStr}</span>
      {readTime && <span>{readTime}</span>}
      {relatedEssay && (
        <span class="interlude-strip__back">← 第{String(relatedEssay).padStart(2, '0')}話の余白から</span>
      )}
    </div>
  </div>
  {mark && <span class={stampClass}>{mark}</span>}
</Tag>

<style>
  .interlude-strip {
    background: var(--bg-elev);
    border: 1px solid var(--hairline);
    border-left: 4px solid var(--secondary);
    border-radius: 10px;
    padding: 18px 22px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 18px;
    align-items: center;
    position: relative;
    transition: transform .25s, box-shadow .25s;
    text-decoration: none;
    color: var(--text);
  }
  .interlude-strip:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(45,36,25,0.06);
  }
  .interlude-strip::before {
    content: "";
    position: absolute;
    inset: 8px 8px 8px 16px;
    background-image:
      linear-gradient(to bottom, rgba(232, 174, 84, 0.16) 0 1px, transparent 1px 14px);
    background-size: 14px 14px;
    opacity: 0.5; pointer-events: none;
  }

  .interlude-strip__num {
    font-family: var(--font-serif); font-weight: 700; font-size: 22px;
    color: #8a5a1c; line-height: 1; min-width: 50px;
    z-index: 2;
  }
  .interlude-strip__num small {
    display: block;
    font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.18em;
    color: #b07332; font-weight: 500; margin-bottom: 4px; text-transform: uppercase;
  }
  .interlude-strip__body { z-index: 2; min-width: 0; }
  .interlude-strip__title {
    font-family: var(--font-heading); font-weight: 700; font-size: 14.5px; line-height: 1.65;
    color: var(--text);
    display: flex; align-items: center; gap: 10px;
  }
  .interlude-strip__title-text { flex: 1; }
  .interlude-strip__meta {
    margin-top: 4px;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
    color: var(--muted); text-transform: uppercase;
    display: flex; gap: 12px; flex-wrap: wrap;
  }
  .interlude-strip__back {
    color: #8a5a1c;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 11.5px;
    text-transform: none;
    letter-spacing: 0;
  }
  .interlude-strip__stamp { z-index: 3; }

  .is-draft.interlude-strip { opacity: 0.7; cursor: default; }
  .is-draft .interlude-strip__num { color: var(--muted); }
  .is-draft .interlude-strip__title { color: var(--text-dim); }
  .is-draft .interlude-strip__back { color: var(--muted); }

  @media (max-width: 600px) {
    .interlude-strip { grid-template-columns: auto 1fr; padding: 14px 16px; gap: 12px; }
    .interlude-strip__stamp { grid-column: 1 / -1; justify-self: flex-end; }
  }
</style>
